# ============================================================
# api-inadimplencia - .env.example
# Copiar para .env e preencher os valores faltantes
# ============================================================

INAD_PORT=8080

# --- SQL Server (DW) ---
INAD_DB_USER=dwbi
INAD_DB_PASSWORD=__SECRET__
INAD_DB_SERVER=192.168.79.240\bi
INAD_DB_DATABASE=dwjnc
INAD_DB_PORT=10433
INAD_DB_ENCRYPT=true
INAD_DB_TRUST_CERT=true

# --- Fluig ---
INAD_FLUIG_URL=https://hmfluig.jotanunes.com
INAD_FLUIG_USER=wffluig
INAD_FLUIG_PASSWORD=__SECRET__

# --- RM ---
# Defaults usados pelo handler de ficha-financeira quando o front nao envia
# codColigada/reportColigada/reportId. ReportCode/ReportName so sao usados no
# fallback que pesquisa o relatorio em ds_paiFilho_controleDeAcessoRMreportsFluig.
INAD_RM_COLIGADA=1
INAD_RM_REPORT_COLIGADA=0
INAD_RM_PARAM_COLIGADA=1
INAD_RM_REPORT_ID=1028
INAD_RM_REPORT_CODE=1028
INAD_RM_REPORT_NAME=Ficha Financeira
INAD_RM_DEBUG=false

# ============================================================
# Serasa PEFIN
# Doc oficial: documentos/documentacao-serasa-pefin-v8.md
#
# Selecione UM dos blocos abaixo (PROD ou UAT) e descomente.
# ============================================================

# --- PRODUCAO (default) ---
INAD_SERASA_ENV=prod
INAD_SERASA_AUTH_URL=https://api.serasaexperian.com.br/security/iam/v1/client-identities/login
INAD_SERASA_COLLECTION_BASE_URL=https://api.serasa.com.br/collection
INAD_SERASA_CLIENT_ID=__PREENCHA_CLIENT_ID_PROD__
INAD_SERASA_CLIENT_SECRET=__PREENCHA_CLIENT_SECRET_PROD__
INAD_SERASA_LOGON_VINCULADO=99009720
INAD_SERASA_CNPJ_CONTRATO=16202491000193
INAD_SERASA_USE_UAT_DEFAULTS=false
INAD_SERASA_CREDITOR_DOCUMENT=16202491000193
INAD_SERASA_AREA_INFORMANTE=0001

# --- HOMOLOGACAO (UAT) - descomentar para usar ---
# INAD_SERASA_ENV=uat
# INAD_SERASA_AUTH_URL=https://uat-api.serasaexperian.com.br/security/iam/v1/client-identities/login
# INAD_SERASA_COLLECTION_BASE_URL=https://api.serasa.dev/collection
# INAD_SERASA_CLIENT_ID=__PREENCHA_CLIENT_ID_UAT__
# INAD_SERASA_CLIENT_SECRET=__PREENCHA_CLIENT_SECRET_UAT__
# INAD_SERASA_LOGON_VINCULADO=99009720
# INAD_SERASA_CNPJ_CONTRATO=16202491000193
# INAD_SERASA_USE_UAT_DEFAULTS=true
# INAD_SERASA_CREDITOR_DOCUMENT=16202491000193
# INAD_SERASA_AREA_INFORMANTE=0001

# --- Auth / Entra ID / CORS ---
INAD_AUTH_URL=http://localhost:3013
INAD_AUTH_INTERNAL_ORIGIN=https://fluig.jotanunes.com,http://localhost:5173
INAD_CORS_ALLOWED_ORIGINS=https://fluig.jotanunes.com,https://hmfluig.jotanunes.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
INAD_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
INAD_CORS_ALLOWED_HEADERS=Accept,Authorization,Cache-Control,Content-Type,Origin,Pragma,X-Requested-With,X-User-Code,X-User-Name,X-Username
INAD_CORS_EXPOSED_HEADERS=Content-Disposition,X-Correlation-Id,X-Request-Id
INAD_CORS_ALLOW_CREDENTIALS=true
INAD_CORS_PREFLIGHT_MAX_AGE_SECONDS=3600
INAD_CREDENTIALS_ENCRYPTION_KEY=__SECRET__
INAD_REQUIRE_AUTHENTICATED=true
INAD_ENTRA_TENANT_ID=__TENANT_ID__
INAD_ENTRA_API_CLIENT_ID=__API_CLIENT_ID__
INAD_ENTRA_AUDIENCE=api://__API_CLIENT_ID__
INAD_ENTRA_CLIENT_ID=__CLIENT_ID__
INAD_ENTRA_CLIENT_SECRET=__SECRET__
INAD_ENTRA_SCOPE=api://__API_CLIENT_ID__/API.Access
INAD_ENTRA_REDIRECT_URIS=https://fluig.jotanunes.com/portal/p/1/pg_inadimplencia/home/configuracao,http://localhost:5173