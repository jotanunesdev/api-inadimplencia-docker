{
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Fluig": {
    "Url": "",
    "User": "",
    "Password": ""
  },
  "Rm": {
    "Coligada": 1,
    "ReportColigada": 0,
    "ParamColigada": 1,
    "ReportId": 1028,
    "ReportCode": "1028",
    "ReportName": "Ficha Financeira",
    "Debug": false
  },
  "SerasaPefin": {
    "Env": "prod",
    "AuthUrl": "https://api.serasaexperian.com.br/security/iam/v1/client-identities/login",
    "CollectionBaseUrl": "https://api.serasa.com.br/collection",
    "ClientId": "",
    "ClientSecret": "",
    "LogonVinculado": "",
    "CnpjContrato": "",
    "UseUatDefaults": false,
    "CreditorDocument": "",
    "AreaInformante": ""
  },
  "Auth": {
    "AuthServerBaseUrl": "http://localhost:3013",
    "InternalOrigin": "https://fluig.jotanunes.com",
    "AuthServerTimeoutSeconds": 15,
    "CredentialsEncryptionKey": "",
    "SessionCookieSameSite": "lax",
    "RequireAuthenticatedInadimplencia": true
  },
  "Cors": {
    "AllowedOrigins": "https://fluig.jotanunes.com,https://hmfluig.jotanunes.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000",
    "AllowedMethods": "GET,POST,PUT,DELETE,OPTIONS",
    "AllowedHeaders": "Accept,Authorization,Cache-Control,Content-Type,Origin,Pragma,X-Requested-With,X-User-Code,X-User-Name,X-Username,X-Source-System,X-System-Name,X-Client-Id",
    "ExposedHeaders": "Content-Disposition,X-Correlation-Id,X-Request-Id",
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 3600
  },
  "TrafficMonitoring": {
    "Enabled": true,
    "ApplicationName": "api-inadimplencia",
    "SourceSystemHeader": "X-Source-System",
    "ChannelCapacity": 10000,
    "BatchSize": 250,
    "FlushIntervalSeconds": 5,
    "MaxAnalyticsPeriodDays": 90,
    "ExcludedPathPrefixes": [
      "/traffic-monitoring",
      "/health",
      "/metrics",
      "/swagger",
      "/notifications/stream",
      "/inadimplencia/notifications/stream"
    ]
  },
  "AuditDb": {
    "ConnectionString": "",
    "CommandTimeoutSeconds": 60
  },
  "Negativacao": {
    "UsuariosAprovadores": ["gustavo.trindade", "aracy.mendonca", "adriano.oliveira"],
    "SuperDecisores": [
      "gustavo.trindade"
    ],
    "QuorumAprovacao": 1,
    "DiasAtrasoMinimo": 60,
    "MaxTentativasSenha": 3,
    "LockoutMinutos": 15,
    "JanelaTentativasMinutos": 5
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "RabbitMQ": "amqp://guest:guest@localhost:5672/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "MassTransit": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironment"
    ]
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*"
}
